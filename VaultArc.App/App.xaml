<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="VaultArc.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="VaultArcBackgroundBrush" Color="#ECEFF3" />
                    <SolidColorBrush x:Key="VaultArcSurfaceBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="VaultArcListAccentBrush" Color="#E2E8F0" />
                    <SolidColorBrush x:Key="VaultArcPrimaryAccentBrush" Color="#2563EB" />
                    <SolidColorBrush x:Key="VaultArcPrimaryTextBrush" Color="#0F172A" />
                    <SolidColorBrush x:Key="VaultArcClassicChromeBrush" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="VaultArcClassicChromeBorderBrush" Color="#C8C8C8" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="VaultArcBackgroundBrush" Color="#101418" />
                    <SolidColorBrush x:Key="VaultArcSurfaceBrush" Color="#1B2430" />
                    <SolidColorBrush x:Key="VaultArcListAccentBrush" Color="#253248" />
                    <SolidColorBrush x:Key="VaultArcPrimaryAccentBrush" Color="#4F8CFF" />
                    <SolidColorBrush x:Key="VaultArcPrimaryTextBrush" Color="#F2F6FA" />
                    <SolidColorBrush x:Key="VaultArcClassicChromeBrush" Color="#252B36" />
                    <SolidColorBrush x:Key="VaultArcClassicChromeBorderBrush" Color="#3D4A5C" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
