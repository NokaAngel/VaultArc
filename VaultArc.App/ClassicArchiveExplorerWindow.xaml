<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VaultArc.App.ClassicArchiveExplorerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:VaultArc.Models"
    xmlns:local="using:VaultArc.App"
    Title="VaultArc — Classic Explorer">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource VaultArcBackgroundBrush}"
          AllowDrop="True" DragOver="Grid_DragOver" Drop="Grid_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="0,1"
            Background="{ThemeResource VaultArcClassicChromeBrush}"
            BorderBrush="{ThemeResource VaultArcClassicChromeBorderBrush}"
            BorderThickness="0,0,0,1">
            <MenuBar Background="Transparent">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Click="BrowseClicked" Text="Open Archive..." />
                    <MenuFlyoutItem Click="CreateArchiveMenuClicked" Text="Create Archive" />
                    <MenuFlyoutItem Click="ExtractMenuClicked" Text="Extract to..." />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Click="CloseClicked" Text="Close" />
                </MenuBarItem>
                <MenuBarItem Title="Actions">
                    <MenuFlyoutItem Click="OpenSelectedClicked" Text="Open" />
                    <MenuFlyoutItem Click="RunSelectedClicked" Text="Run" />
                    <MenuFlyoutItem Click="ViewTempFolderClicked" Text="Open temp folder" />
                    <MenuFlyoutItem Click="PreviewClicked" Text="Preview" />
                    <MenuFlyoutItem Click="IntegrityClicked" Text="Test integrity" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Click="RenameEntryClicked" Text="Rename (.arc)" />
                    <MenuFlyoutItem Click="DeleteEntryClicked" Text="Delete (.arc)" />
                </MenuBarItem>
                <MenuBarItem Title="Tools">
                    <MenuFlyoutItem Click="FindClicked" Text="Find" />
                    <MenuFlyoutItem Click="RefreshClicked" Text="Refresh" />
                    <MenuFlyoutItem Click="CopyPathClicked" Text="Copy path" />
                </MenuBarItem>
                <MenuBarItem Title="Help">
                    <MenuFlyoutItem Click="HelpClicked" Text="About" />
                </MenuBarItem>
            </MenuBar>
        </Border>

        <Border
            Grid.Row="1"
            Padding="4,3"
            Background="{ThemeResource VaultArcClassicChromeBrush}"
            BorderBrush="{ThemeResource VaultArcClassicChromeBorderBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="1">
                <Button Width="34" Height="26" Padding="0" Click="CreateArchiveMenuClicked" ToolTipService.ToolTip="Create">
                    <FontIcon FontSize="14" Glyph="&#xE8A5;" />
                </Button>
                <Button Width="34" Height="26" Padding="0" Click="ExtractMenuClicked" ToolTipService.ToolTip="Extract">
                    <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                </Button>
                <Rectangle Width="1" Height="20" Margin="3,0" Fill="{ThemeResource VaultArcClassicChromeBorderBrush}" />
                <Button Width="34" Height="26" Padding="0" Click="OpenSelectedClicked" ToolTipService.ToolTip="Open">
                    <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                </Button>
                <Button Width="34" Height="26" Padding="0" Click="RunSelectedClicked" ToolTipService.ToolTip="Run">
                    <FontIcon FontSize="14" Glyph="&#xE768;" />
                </Button>
                <Button Width="34" Height="26" Padding="0" Click="IntegrityClicked" ToolTipService.ToolTip="Test">
                    <FontIcon FontSize="14" Glyph="&#xE9CE;" />
                </Button>
                <Button Width="34" Height="26" Padding="0" Click="DeleteEntryClicked" ToolTipService.ToolTip="Delete">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                </Button>
                <Rectangle Width="1" Height="20" Margin="3,0" Fill="{ThemeResource VaultArcClassicChromeBorderBrush}" />
                <Button Width="34" Height="26" Padding="0" Click="FindClicked" ToolTipService.ToolTip="Find">
                    <FontIcon FontSize="14" Glyph="&#xE721;" />
                </Button>
                <Button Width="34" Height="26" Padding="0" Click="RefreshClicked" ToolTipService.ToolTip="Refresh">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="2"
            Padding="8,5"
            Background="{ThemeResource VaultArcSurfaceBrush}"
            BorderBrush="{ThemeResource VaultArcClassicChromeBorderBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Width="28" Height="26" Padding="0" Click="NavigateRootClicked" ToolTipService.ToolTip="Root">
                    <FontIcon FontSize="13" Glyph="&#xE80F;" />
                </Button>
                <Button Width="28" Height="26" Padding="0" Click="NavigateUpClicked" IsEnabled="{x:Bind ViewModel.CanNavigateUp, Mode=OneWay}" ToolTipService.ToolTip="Up">
                    <FontIcon FontSize="13" Glyph="&#xE74A;" />
                </Button>
                <Image Width="18" Height="18" VerticalAlignment="Center" Source="{x:Bind ViewModel.ArchiveIconPath, Mode=OneWay}" />
                <TextBox
                    MinWidth="380"
                    VerticalAlignment="Center"
                    PlaceholderText="Archive path"
                    Text="{x:Bind ViewModel.ArchivePath, Mode=TwoWay}" />
                <Button Height="26" Padding="10,0" Click="BrowseClicked" Content="Browse" />
                <Button Height="26" Padding="10,0" Click="OpenClicked" Content="Open" Style="{ThemeResource AccentButtonStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="8,5" Background="{ThemeResource VaultArcSurfaceBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="ClassicSearchBox" MinWidth="180" PlaceholderText="Search" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />
                        <CheckBox Content="Executables only" IsChecked="{x:Bind ViewModel.ShowExecutablesOnly, Mode=TwoWay}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" Padding="8,5" ColumnSpacing="4" Background="{ThemeResource VaultArcListAccentBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="Name" />
                    <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Text="Type" />
                    <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" Text="Size" />
                    <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold" Text="Packed" />
                    <TextBlock Grid.Column="4" FontSize="12" FontWeight="SemiBold" Text="Modified" />
                </Grid>

                <ListView
                    Grid.Row="2"
                    x:Name="ClassicEntriesList"
                    Padding="2,0"
                    Background="{ThemeResource VaultArcBackgroundBrush}"
                    ItemsSource="{x:Bind ViewModel.FilteredItems, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                    DoubleTapped="EntriesList_DoubleTapped"
                    KeyDown="EntriesList_KeyDown">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ArchiveItem">
                            <Grid Padding="4,3" ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1.4*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontSize="13" Glyph="{x:Bind local:ClassicArchiveExplorerWindow.GetEntryIcon(FullPath, IsDirectory)}" Opacity="0.7" />
                                    <TextBlock FontSize="12" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" FontSize="12" Opacity="0.7" Text="{x:Bind ItemType}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontSize="12" Opacity="0.7" Text="{x:Bind Size}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" FontSize="12" Opacity="0.7" Text="{x:Bind CompressedSize}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" FontSize="12" Opacity="0.7" Text="{x:Bind ModifiedUtc}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Border
                Grid.Column="1"
                Background="{ThemeResource VaultArcSurfaceBrush}"
                BorderBrush="{ThemeResource VaultArcClassicChromeBorderBrush}"
                BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="Selected" />
                            <TextBlock FontSize="12" Text="{x:Bind ViewModel.SelectedDisplayName, Mode=OneWay}" TextWrapping="Wrap" />
                            <TextBlock FontSize="11" Opacity="0.65" Text="{x:Bind ViewModel.SelectedFullPath, Mode=OneWay}" TextWrapping="Wrap" />
                            <Button HorizontalAlignment="Stretch" Click="PreviewClicked">
                                <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                    <FontIcon FontSize="13" Glyph="&#xE8A5;" />
                                    <TextBlock FontSize="12" Text="Preview" />
                                </StackPanel>
                            </Button>
                            <TextBox
                                MinHeight="120"
                                AcceptsReturn="True"
                                IsReadOnly="True"
                                FontSize="12"
                                Text="{x:Bind ViewModel.PreviewText, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource VaultArcClassicChromeBorderBrush}" />

                        <StackPanel Spacing="6">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="Extract" />
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    PlaceholderText="Destination folder"
                                    Text="{x:Bind ViewModel.ExtractDestination, Mode=TwoWay}"
                                    FontSize="12" />
                                <Button Grid.Column="1" Click="BrowseExtractDestinationClicked" ToolTipService.ToolTip="Browse">
                                    <FontIcon FontSize="13" Glyph="&#xE838;" />
                                </Button>
                            </Grid>
                            <CheckBox Content="Overwrite existing" FontSize="12" IsChecked="{x:Bind ViewModel.ExtractOverwrite, Mode=TwoWay}" />
                            <Button
                                Click="ExtractAllClicked"
                                HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.HasArchiveLoaded, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                                    <FontIcon FontSize="13" Glyph="&#xE896;" />
                                    <TextBlock FontSize="12" Text="Extract All" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border
            Grid.Row="4"
            Padding="8,4"
            Background="{ThemeResource VaultArcClassicChromeBrush}"
            BorderBrush="{ThemeResource VaultArcClassicChromeBorderBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock FontSize="12" VerticalAlignment="Center" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Text="{x:Bind ViewModel.StatusBarSummary, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</Window>
