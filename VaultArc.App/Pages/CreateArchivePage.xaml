<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VaultArc.App.Pages.CreateArchivePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop">
    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
        <Grid Padding="32,28,32,20" MaxWidth="700" HorizontalAlignment="Left" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Create Archive" />

            <!-- Destination -->
            <Border Grid.Row="1" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Destination" />
                    <TextBox PlaceholderText="Output path (.zip, .tar, .tar.gz, .tar.xz, .arc)" Text="{x:Bind ViewModel.DestinationPath, Mode=TwoWay}" />
                    <Button Click="BrowseDestinationClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                            <TextBlock Text="Browse" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Compression & Encryption -->
            <Border Grid.Row="2" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            Header="Compression preset"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.Presets}"
                            SelectedItem="{x:Bind ViewModel.Preset, Mode=TwoWay}" />
                        <ComboBox
                            Grid.Column="1"
                            Header="Encryption (.arc only)"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.EncryptionProfiles}"
                            SelectedItem="{x:Bind ViewModel.EncryptionProfile, Mode=TwoWay}" />
                    </Grid>
                    <!-- Password strength meter -->
                    <StackPanel x:Name="PasswordStrengthPanel" Spacing="6" Visibility="Collapsed">
                        <TextBlock FontSize="12" Opacity="0.6" Text="Password strength" />
                        <ProgressBar x:Name="PasswordStrengthBar" Maximum="100" Value="0" Height="6" />
                        <TextBlock x:Name="PasswordStrengthLabel" FontSize="12" Opacity="0.7" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Input files -->
            <Border Grid.Row="3" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Input files" />
                    <TextBlock FontSize="12" Opacity="0.65" Text="One file or folder path per line, or drag and drop files/folders here." TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="BrowseInputFolderClicked">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE838;" />
                                <TextBlock Text="Add folder" />
                            </StackPanel>
                        </Button>
                        <Button Click="BrowseInputFilesClicked">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE8E5;" />
                                <TextBlock Text="Add files" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBox
                        AcceptsReturn="True"
                        MinHeight="160"
                        Text="{x:Bind ViewModel.InputPaths, Mode=TwoWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Queue -->
            <StackPanel Grid.Row="4" Spacing="10">
                <Button Click="QueueClicked" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE7C3;" />
                        <TextBlock Text="Queue compression" />
                    </StackPanel>
                </Button>
                <TextBlock FontSize="13" Opacity="0.75" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
