<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VaultArc.App.Pages.ExtractPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
        <Grid Padding="32,28,32,20" MaxWidth="700" HorizontalAlignment="Left" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Extract Archive" />

            <Border Grid.Row="1" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Source" />
                    <TextBox PlaceholderText="Archive path" Text="{x:Bind ViewModel.ArchivePath, Mode=TwoWay}" />
                    <Button Click="BrowseArchiveClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                            <TextBlock Text="Browse archive" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Destination" />
                    <TextBox PlaceholderText="Output folder" Text="{x:Bind ViewModel.DestinationPath, Mode=TwoWay}" />
                    <Button Click="BrowseDestinationClicked">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE838;" />
                            <TextBlock Text="Browse folder" />
                        </StackPanel>
                    </Button>
                    <CheckBox Content="Overwrite existing files" IsChecked="{x:Bind ViewModel.OverwriteExisting, Mode=TwoWay}" />
                    <TextBlock FontSize="12" Opacity="0.65" Text="Password prompts appear only if the archive requires one." TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Spacing="10">
                <Button Click="QueueClicked" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE8B9;" />
                        <TextBlock Text="Queue extraction" />
                    </StackPanel>
                </Button>
                <TextBlock
                    FontSize="13"
                    Opacity="0.75"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
