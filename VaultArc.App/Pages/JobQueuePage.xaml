<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VaultArc.App.Pages.JobQueuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:VaultArc.App.ViewModels">
    <Grid RowSpacing="0" Background="{ThemeResource VaultArcBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="32,20,32,12">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Job Queue" VerticalAlignment="Center" />
                <Button Click="RefreshClicked" VerticalAlignment="Center" ToolTipService.ToolTip="Refresh">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
            </StackPanel>
        </Border>

        <ListView
            Grid.Row="1"
            Padding="20,0"
            ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:JobQueueItemView">
                    <Border
                        Margin="0,0,0,8"
                        Padding="16,12"
                        CornerRadius="8"
                        Background="{ThemeResource VaultArcSurfaceBrush}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                                <Border Padding="8,2" CornerRadius="4" Background="{ThemeResource VaultArcListAccentBrush}">
                                    <TextBlock FontSize="11" Text="{x:Bind StateLabel}" />
                                </Border>
                                <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center" Text="{x:Bind ProgressText}" />
                            </StackPanel>
                            <ProgressBar Maximum="100" Value="{x:Bind ProgressPercent}" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock FontSize="12" Opacity="0.65" Text="{x:Bind ElapsedText}" />
                                <TextBlock FontSize="12" Opacity="0.65" Text="{x:Bind EtaText}" />
                                <Button
                                    Height="26"
                                    Padding="10,0"
                                    Click="CancelJobClicked"
                                    Content="Cancel"
                                    FontSize="12"
                                    IsEnabled="{x:Bind IsInProgress}"
                                    Tag="{x:Bind JobId}" />
                            </StackPanel>
                            <TextBlock FontSize="12" Opacity="0.7" Text="{x:Bind StatusMessage}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Padding="32,8">
            <TextBlock FontSize="13" Opacity="0.75" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </Border>
    </Grid>
</Page>
