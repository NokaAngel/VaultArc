<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VaultArc.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
        <Grid Padding="32,28,32,20" MaxWidth="640" HorizontalAlignment="Left" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Settings" />

            <!-- Appearance -->
            <Border Grid.Row="1" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Appearance" />
                    <ToggleSwitch
                        Header="Follow Windows theme"
                        IsOn="{x:Bind ViewModel.FollowSystemTheme, Mode=TwoWay}"
                        Toggled="ThemeOptionChanged" />
                    <TextBlock FontSize="12" Opacity="0.6" Margin="0,-8,0,0"
                               Text="Automatically switches between light and dark when Windows changes." TextWrapping="WrapWholeWords" />
                    <ToggleSwitch
                        Header="Dark mode (manual)"
                        IsOn="{x:Bind ViewModel.IsDarkTheme, Mode=TwoWay}"
                        IsEnabled="{x:Bind InvertBool(ViewModel.FollowSystemTheme), Mode=OneWay}"
                        Toggled="ThemeOptionChanged" />
                </StackPanel>
            </Border>

            <!-- Archive Explorer -->
            <Border Grid.Row="2" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Archive Explorer" />
                    <CheckBox
                        Content="Use classic WinRAR-style explorer window"
                        IsChecked="{x:Bind ViewModel.UseClassicLayout, Mode=TwoWay}" />
                    <TextBlock FontSize="12" Opacity="0.6" Margin="0,-8,0,0"
                               Text="Opens archives in a separate window with a traditional menu bar, toolbar, and status bar."
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <!-- Shell Integration -->
            <Border Grid.Row="3" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Shell Integration" />
                    <ToggleSwitch
                        Header="Windows right-click context menu"
                        IsOn="{x:Bind ViewModel.ShellContextMenuEnabled, Mode=TwoWay}" />
                    <TextBlock FontSize="12" Opacity="0.6" Margin="0,-8,0,0"
                               Text="Adds 'Open with VaultArc', 'Extract here', and 'Add to archive' to the Explorer right-click menu for archive files."
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <!-- Safety -->
            <Border Grid.Row="4" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Safety" />
                    <CheckBox
                        Content="Confirm before overwriting files"
                        IsChecked="{x:Bind ViewModel.ConfirmOverwrite, Mode=TwoWay}" />
                    <CheckBox
                        Content="Safe extraction mode (block path traversal)"
                        IsChecked="{x:Bind ViewModel.SafeExtractionMode, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Performance -->
            <Border Grid.Row="5" Padding="20" CornerRadius="8" Background="{ThemeResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Performance" />
                    <NumberBox
                        Header="Max concurrent jobs"
                        Minimum="1"
                        Maximum="8"
                        SpinButtonPlacementMode="Compact"
                        Value="{x:Bind ViewModel.MaxConcurrentJobs, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Save -->
            <StackPanel Grid.Row="6" Spacing="10">
                <Button Click="SaveClicked" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontSize="14" Glyph="&#xE74E;" />
                        <TextBlock Text="Save settings" />
                    </StackPanel>
                </Button>
                <TextBlock
                    FontSize="13"
                    Opacity="0.75"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
