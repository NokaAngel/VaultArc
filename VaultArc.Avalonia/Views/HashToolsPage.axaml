<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VaultArc.Avalonia.ViewModels"
             xmlns:models="using:VaultArc.Models"
             x:Class="VaultArc.Avalonia.Views.HashToolsPage"
             x:DataType="vm:HashToolsViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,28,32,20" MaxWidth="700" HorizontalAlignment="Left" RowDefinitions="Auto,20,Auto,20,Auto,20,Auto,20,Auto">

            <TextBlock FontSize="28" FontWeight="SemiBold" Text="Hash Tools" />

            <Border Grid.Row="2" Padding="20" CornerRadius="8" Background="{DynamicResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="12" Text="Algorithm" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Algorithms}" SelectedItem="{Binding Algorithm, Mode=TwoWay}" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                        <TextBox Watermark="File path" Text="{Binding LeftFilePath, Mode=TwoWay}" />
                        <Button Grid.Column="2" x:Name="BrowseLeftBtn" Content="📂" ToolTip.Tip="Browse" />
                        <Button Grid.Column="4" x:Name="HashBtn" Classes="accent" Content="Hash" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Padding="20" CornerRadius="8" Background="{DynamicResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Compare" />
                    <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                        <TextBox Watermark="Second file path" Text="{Binding RightFilePath, Mode=TwoWay}" />
                        <Button Grid.Column="2" x:Name="BrowseRightBtn" Content="📂" ToolTip.Tip="Browse" />
                        <Button Grid.Column="4" x:Name="CompareBtn" Content="Compare" />
                    </Grid>
                    <TextBlock FontWeight="SemiBold" Text="{Binding ComparisonResult}" TextWrapping="WrapWithOverflow" />
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Padding="20" CornerRadius="8" Background="{DynamicResource VaultArcSurfaceBrush}">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Results" VerticalAlignment="Center" />
                        <Button x:Name="ExportBtn" Content="Export report" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Hashes}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:HashReportItem">
                                <StackPanel Margin="0,4,0,0" Spacing="2">
                                    <TextBlock FontSize="12" Opacity="0.7" Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" />
                                    <SelectableTextBlock FontFamily="Cascadia Mono,Consolas,monospace" FontSize="13" Text="{Binding HashHex}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="8" FontSize="13" Opacity="0.75" Text="{Binding StatusMessage}" TextWrapping="WrapWithOverflow" />
        </Grid>
    </ScrollViewer>
</UserControl>
