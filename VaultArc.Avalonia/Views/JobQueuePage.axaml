<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VaultArc.Avalonia.ViewModels"
             x:Class="VaultArc.Avalonia.Views.JobQueuePage"
             x:DataType="vm:JobQueueViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource VaultArcBackgroundBrush}">

        <Border Padding="32,20,32,12">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="Job Queue" VerticalAlignment="Center" />
                <Button x:Name="RefreshBtn" Content="🔄" ToolTip.Tip="Refresh" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <ListBox Grid.Row="1" Padding="20,0" ItemsSource="{Binding Jobs}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:JobQueueItemView">
                    <Border Margin="0,0,0,8" Padding="16,12" CornerRadius="8"
                            Background="{DynamicResource VaultArcSurfaceBrush}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                <Border Padding="8,2" CornerRadius="4" Background="{DynamicResource VaultArcListAccentBrush}">
                                    <TextBlock FontSize="11" Text="{Binding StateLabel}" />
                                </Border>
                                <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center" Text="{Binding ProgressText}" />
                            </StackPanel>
                            <ProgressBar Maximum="100" Value="{Binding ProgressPercent}" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock FontSize="12" Opacity="0.65" Text="{Binding ElapsedText}" />
                                <TextBlock FontSize="12" Opacity="0.65" Text="{Binding EtaText}" />
                            </StackPanel>
                            <TextBlock FontSize="12" Opacity="0.7" Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Padding="32,8">
            <TextBlock FontSize="13" Opacity="0.75" Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</UserControl>
