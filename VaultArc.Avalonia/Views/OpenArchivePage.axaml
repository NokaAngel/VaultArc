<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VaultArc.Avalonia.ViewModels"
             xmlns:models="using:VaultArc.Models"
             x:Class="VaultArc.Avalonia.Views.OpenArchivePage"
             x:DataType="vm:OpenArchiveViewModel">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource VaultArcBackgroundBrush}">

        <Border Grid.Row="0" Padding="20,16" Background="{DynamicResource VaultArcSurfaceBrush}">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBox MinWidth="400" Watermark="Archive path"
                             Text="{Binding ArchivePath, Mode=TwoWay}" />
                    <Button x:Name="BrowseBtn" Content="📂" ToolTip.Tip="Browse for archive" />
                    <Button x:Name="OpenBtn" Classes="accent" ToolTip.Tip="Open archive">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📄" />
                            <TextBlock Text="Open" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="IntegrityBtn" Content="✓" ToolTip.Tip="Test archive integrity" />
                    <TextBox MinWidth="180" Watermark="Password (if encrypted)" PasswordChar="*" Text="{Binding Password, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="20" Margin="0,8,0,0">
                    <TextBlock FontSize="12" Opacity="0.65">
                        <Run Text="Entries: " /><Run FontWeight="SemiBold" Text="{Binding TotalEntryCount}" />
                    </TextBlock>
                    <TextBlock FontSize="12" Opacity="0.65">
                        <Run Text="Runnable: " /><Run FontWeight="SemiBold" Text="{Binding ExecutableCount}" />
                    </TextBlock>
                    <TextBlock FontSize="12" Opacity="0.65">
                        <Run Text="Location: " /><Run FontWeight="SemiBold" Text="{Binding CurrentFolderPath}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="12,6" Background="{DynamicResource VaultArcSurfaceBrush}"
                BorderBrush="{DynamicResource VaultArcListAccentBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="RootBtn" Width="32" Height="28" Padding="0" Content="🏠" ToolTip.Tip="Root" />
                <Button x:Name="UpBtn" Width="32" Height="28" Padding="0" Content="⬆" IsEnabled="{Binding CanNavigateUp}" ToolTip.Tip="Up one level" />
                <Separator Width="1" Height="18" Margin="4,0" />
                <Button x:Name="OpenSelBtn" Height="28" Padding="8,0" IsEnabled="{Binding CanOpenSelected}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock FontSize="12" Text="Open" />
                    </StackPanel>
                </Button>
                <Button x:Name="RunSelBtn" Height="28" Padding="8,0" IsEnabled="{Binding CanRunSelected}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock FontSize="12" Text="Run" />
                    </StackPanel>
                </Button>
                <Button x:Name="TempBtn" Height="28" Padding="8,0">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock FontSize="12" Text="Temp" />
                    </StackPanel>
                </Button>
                <Button x:Name="RefreshBtn" Width="32" Height="28" Padding="0" Content="🔄" ToolTip.Tip="Refresh" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,300">
            <Grid RowDefinitions="Auto,Auto,*">
                <Border Padding="12,8" Background="{DynamicResource VaultArcSurfaceBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="SearchBox" MinWidth="200" Watermark="Search entries..."
                                 Text="{Binding SearchText, Mode=TwoWay}" />
                        <CheckBox Content="Executables only" IsChecked="{Binding ShowExecutablesOnly, Mode=TwoWay}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="12,6" Background="{DynamicResource VaultArcListAccentBrush}">
                    <Grid ColumnDefinitions="3*,*,1.2*,1.2*,1.8*">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Name" />
                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Text="Type" />
                        <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold" Text="Size" />
                        <TextBlock Grid.Column="3" FontSize="12" FontWeight="SemiBold" Text="Packed" />
                        <TextBlock Grid.Column="4" FontSize="12" FontWeight="SemiBold" Text="Modified" />
                    </Grid>
                </Border>

                <ListBox Grid.Row="2" x:Name="EntriesList" Padding="4,0"
                         Background="{DynamicResource VaultArcBackgroundBrush}"
                         ItemsSource="{Binding FilteredItems}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ArchiveItem">
                            <Grid Margin="6,4" ColumnDefinitions="3*,*,1.2*,1.2*,1.8*">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock FontSize="14" Opacity="0.75"
                                               Text="📄" />
                                    <TextBlock FontSize="13" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" FontSize="13" Opacity="0.7" Text="{Binding ItemType}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" FontSize="13" Opacity="0.7" Text="{Binding Size}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" FontSize="13" Opacity="0.7" Text="{Binding CompressedSize}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" FontSize="13" Opacity="0.7" Text="{Binding ModifiedUtc}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Border Grid.Column="1" Background="{DynamicResource VaultArcSurfaceBrush}"
                    BorderBrush="{DynamicResource VaultArcListAccentBrush}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Details" />
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" Opacity="0.6" Text="Name" />
                                <TextBlock FontSize="13" Text="{Binding SelectedDisplayName}" TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" Opacity="0.6" Text="Type" />
                                <TextBlock FontSize="13" Text="{Binding SelectedTypeLabel}" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" Opacity="0.6" Text="Size" />
                                <TextBlock FontSize="13" Text="{Binding SelectedSizeLabel}" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" Opacity="0.6" Text="Modified" />
                                <TextBlock FontSize="13" Text="{Binding SelectedModifiedLabel}" />
                            </StackPanel>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="12" Opacity="0.6" Text="Path" />
                                <TextBlock FontSize="12" Opacity="0.8" Text="{Binding SelectedFullPath}" TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                            <Button x:Name="PreviewBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="Preview" />
                            <TextBlock x:Name="TruncationWarning" FontSize="11" Opacity="0.7" Foreground="Orange"
                                       Text="File too large for full preview (showing first 512 KB)" IsVisible="False" Margin="0,0,0,4" />
                            <Image x:Name="PreviewImage" MaxHeight="300" IsVisible="False" Stretch="Uniform" HorizontalAlignment="Left" />
                            <TextBox x:Name="PreviewTextBox" AcceptsReturn="True" IsReadOnly="True" MinHeight="120"
                                     Text="{Binding PreviewText}" TextWrapping="Wrap" FontSize="12" />
                        </StackPanel>

                        <Separator Height="1" Background="{DynamicResource VaultArcListAccentBrush}" />

                        <StackPanel Spacing="8">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Extract Archive" />
                            <TextBlock FontSize="12" Opacity="0.6" Text="Choose a destination folder and extract all entries." TextWrapping="WrapWithOverflow" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Watermark="Destination folder" Text="{Binding ExtractDestination, Mode=TwoWay}" FontSize="12" />
                                <Button Grid.Column="1" x:Name="BrowseExtractBtn" Content="📁" ToolTip.Tip="Browse destination" />
                            </Grid>
                            <CheckBox Content="Overwrite existing files" FontSize="12" IsChecked="{Binding ExtractOverwrite, Mode=TwoWay}" />
                            <Button x:Name="ExtractAllBtn" HorizontalAlignment="Stretch" Classes="accent"
                                    IsEnabled="{Binding HasArchiveLoaded}" HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock FontSize="12" Text="Extract All" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="12,6" Background="{DynamicResource VaultArcSurfaceBrush}"
                BorderBrush="{DynamicResource VaultArcListAccentBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center" Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Text="{Binding StatusBarSummary}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
